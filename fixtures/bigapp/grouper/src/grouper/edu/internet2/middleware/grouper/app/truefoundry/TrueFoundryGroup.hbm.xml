<hibernate-mapping package="edu.internet2.middleware.grouper.app.truefoundry" default-lazy="false">
  <class name="TrueFoundryGroup" table="mock_truefoundry_group">

    <meta attribute="implement-equals">true</meta>
    <meta attribute="session-method">Hib3DAO.getSession();</meta>

    <id name="id" column="id">
      <generator class="assigned" />
    </id>

    <property name="name" column="name" />
    <property name="displayName" column="display_name" />
    <property name="description" column="description" />
    <property name="groupType" column="group_type" />
    <property name="resourceType" column="resource_type" />
    <property name="isDefaultString" column="is_default" />

  </class>
</hibernate-mapping>
